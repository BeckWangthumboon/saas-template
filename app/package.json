    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "convex": "^1.31.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "npm-run-all2": "^8.0.4",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.7"
  }
}
