{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run dev:frontend & bun run dev:backend",
    "dev:frontend": "vite --open",
    "dev:backend": "convex dev",
    "predev": "convex dev --until-success && convex dashboard",
    "generate": "bunx convex dev --once",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "bun run --cwd .. lint",
    "typecheck": "bun run --cwd .. typecheck",
    "format": "bun run --cwd .. format --log-level warn",
    "format:check": "bun run --cwd .. format:check",
    "check": "bun run lint && bun run typecheck && bun run format"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@convex-dev/action-retrier": "^0.3.0",
    "@convex-dev/workos": "^0.0.1",
    "@convex-dev/workos-authkit": "^0.1.6",
    "@convex-dev/workpool": "^0.3.1",
    "@polar-sh/sdk": "^0.42.5",
    "@t3-oss/env-core": "^0.13.10",
    "@tanstack/react-form": "^1.28.0",
    "@tanstack/react-router": "^1.157.18",
    "@tanstack/react-router-devtools": "^1.157.18",
    "@workos-inc/authkit-react": "^0.16.0",
    "@workos-inc/node": "^8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.31.7",
    "convex-helpers": "^0.1.111",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.562.0",
    "neverthrow": "^8.2.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/router-plugin": "^1.157.18",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1"
  }
}
