# Deployment used by `bunx convex dev`
CONVEX_DEPLOYMENT=

# WorkOS Authentication
WORKOS_CLIENT_ID=
WORKOS_API_KEY=

# Autumn Billing
AUTUMN_API_KEY=

# Polar Billing
POLAR_ORGANIZATION_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRO_MONTHLY_PRODUCT_ID=
POLAR_PRO_YEARLY_PRODUCT_ID=
POLAR_SERVER=sandbox

# Resend Email
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_FROM_EMAIL=

# Cloudflare R2 Storage
R2_BUCKET=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# App Configuration
APP_ORIGIN=https://example.com

# Optional: Convex Log Level (debug|info|warn|error, defaults to info)
CONVEX_LOG_LEVEL=info

# Optional: App Environment (dev|prod, defaults to dev)
APP_ENV=dev
